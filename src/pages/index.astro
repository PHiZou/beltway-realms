---
import "../styles/game.css";
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>The Beltway Realms</title>
  </head>
  <body>
    <main style="max-width: 920px; margin: 0 auto; padding: 60px 18px;">
      <h1 style="font-family: serif; font-size: 56px; margin: 0 0 8px;">The Beltway Realms</h1>
      <p style="font-family: serif; opacity: 0.85; font-size: 18px; line-height: 1.5; margin: 0 0 18px;">
        A game-inspired portfolio. Explore Northern Virginia and Washington, D.C. as a parchment overworld: regions, quests, rewards.
      </p>
      <div style="display:flex; gap: 10px; flex-wrap: wrap;">
        <a href="/game/map" style="font-family: serif; text-decoration:none; border: 1px solid rgba(0,0,0,0.22); border-radius: 14px; padding: 10px 14px; background: rgba(242,230,201,0.65);">Start Journey</a>
        <a href="/game/sheet" style="font-family: serif; text-decoration:none; border: 1px solid rgba(0,0,0,0.22); border-radius: 14px; padding: 10px 14px; background: rgba(242,230,201,0.65);">Character Sheet</a>
        <a href="/game/skills" style="font-family: serif; text-decoration:none; border: 1px solid rgba(0,0,0,0.22); border-radius: 14px; padding: 10px 14px; background: rgba(242,230,201,0.65);">Skill Tree</a>
      </div>
    </main>
  </body>
</html>
