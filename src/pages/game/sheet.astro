---
import "../../styles/game.css";
import HUD from "../../components/game/HUD";
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Character Sheet | The Beltway Realms</title>
  </head>
  <body>
    <HUD client:load />
    <main style="max-width: 980px; margin: 0 auto; padding: 18px 18px 48px;">
      <h1 style="font-family: serif; font-size: 40px; margin: 10px 0 8px;">Character Sheet</h1>
      <p style="font-family: serif; opacity: 0.8; margin: 0 0 16px;">
        Placeholder screen. Next: add your resume stats, “equipment” (roles), and achievements.
      </p>
      <ul style="font-family: serif; opacity: 0.8; line-height: 1.6;">
        <li>Systems Thinking: █████</li>
        <li>Data Engineering: ████</li>
        <li>Analytics: █████</li>
        <li>Cloud: ███</li>
        <li>AI Systems: ███</li>
      </ul>
    </main>
  </body>
</html>
