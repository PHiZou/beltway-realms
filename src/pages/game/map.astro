---
import "../../styles/game.css";
import HUD from "../../components/game/HUD";
import WorldMapCanvas from "../../components/game/WorldMap/WorldMapCanvas";
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>World Map | The Beltway Realms</title>
  </head>
  <body>
    <HUD client:load />

    <main class="wrap">
      <header class="header">
        <h1>The Beltway Realms</h1>
        <p>
          A parchment chart of Northern Virginia and the Citadel of Washington. Choose a region and begin your route.
        </p>
      </header>

      <section class="map-frame">
        <WorldMapCanvas client:load />
      </section>
    </main>

    <style>
      .wrap { max-width: 1200px; margin: 0 auto; padding: 18px 18px 40px; }
      .header h1 { font-family: serif; font-size: 40px; margin: 10px 0 6px; }
      .header p { font-family: serif; opacity: 0.8; margin: 0 0 16px; max-width: 900px; }
      .map-frame { padding: 14px; border: 1px solid rgba(0,0,0,0.18); border-radius: 18px; background: rgba(242,230,201,0.55); }
    </style>
  </body>
</html>
